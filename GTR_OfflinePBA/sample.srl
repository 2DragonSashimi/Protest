#test project, RobotMotion_2.srl file
load_tp('default')
execfile('../../robot0/pgm/func_cylinder.srl')
execfile('../../robot0/pgm/Define.srl')
execfile('../../robot0/pgm/func_common.srl')


def Mov002_Inspec_Unload():
    # Program Start #
  
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
  
    # Interface & Update Target #
    target_pos = get_pose('M_prInspec_Unload', stc=1)
  
    ready1_pos = get_pose(target_pos, z=50, stc=1)
  
    complete1_pos = get_pose(target_pos, z=50, stc=1)
  
    # Move Function #  
    movej('M_prInspec_Unload_Ready',t=0.5, stc=1)
    # movej(ready1_pos,r=-1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movej(target_pos,t = 0.7)
    mwait(0.5)
    # movel(complete1_pos,r=-1)
    movej('M_prInspec_Unload_Ready',t = 0.3,stc = 1)
    # Sub Motion #
  
    # Program End #
    return error_code

def Mov003_BotHS_Pickup():
    # Program Start #
    
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
    if isHome_Body() == False:
        error_code = 123121
        return error_code
    
    # Interface & Update Target #
    target_pos = get_pose('M_prBotHS_Pick', stc=1)
  
    # Move Function #  
    movej('M_prBotHS_Pick_Ready', t = 1.0, stc=1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movel(target_pos,t = 1.5)
    mwait(1.0)
    # movel(complete1_pos,r=-1)
    movej('M_prBotHS_Pick_Ready',t = 0.5, stc=1)
  
    # Sub Motion #
  
    # Program End #
    return error_code

def Mov004_BotHS_Load():
    # Program Start #
    
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
    if isHome_Body() == False:
        error_code = 123121
        return error_code
    
    # Interface & Update Target #
    target_pos = get_pose('M_prBotHS_Load', stc=1)
  
    ready1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    complete1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    # Move Function #  
    movej('M_prBotHS_Load_Ready',t = 1.0, stc=1)
    # movej(ready1_pos,r=-1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movel(target_pos,t=1.0)
    mwait(0.5)
    # movel(complete1_pos,r=-1)
    movej('M_prBotHS_Load_Ready',t = 0.5, stc=1)
  
    # Sub Motion #
  
    # Program End #
    return error_code
  
def Mov005_BotHS_Remove():
    # Program Start #
    
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
    if isHome_Body() == False:
        error_code = 123121
        return error_code
    
    # Interface & Update Target #
    target_pos = get_pose('M_prBotHS_Remove', stc=1)
  
    ready1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    complete1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    # Move Function #  
    movej('M_prBotHS_Remove_Ready',t=1.0, stc=1)
    # movej(ready1_pos,r=-1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movel(target_pos,t=1.5)
    mwait(1.0)
    # movel(complete1_pos,r=-1)
    movej('M_prBotHS_Load_Ready',t =0.5, stc=1)
  
    # Sub Motion #
  
    # Program End #
    return error_code
  
def Mov006_PBA_Load():
    # Program Start #
    
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
    if isHome_Body() == False:
        error_code = 123121
        return error_code
    
    # Interface & Update Target #
    target_pos = get_pose('M_prBotHS_Load', stc=1)
  
    ready1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    complete1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    # Move Function #  
    movej('M_prBotHS_Load_Ready',t = 1.0, stc=1)
    # movej(ready1_pos,r=-1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movel(target_pos,t = 1.0)
    mwait(0.5)
    # movel(complete1_pos,r=-1)
    movej('M_prBotHS_Remove_After',t = 0.5, stc=1)
    mwait(4.0)
    # Sub Motion #
  
    # Program End #
    return error_code

