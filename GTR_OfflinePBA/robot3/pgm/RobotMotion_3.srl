def Mov002_Box_Load():
    # Program Start #
    
    # Flag & IO & Cylinder Init #
    error_code = 0
    # Check Work Space #
    #if isReturn_Body() == False:
        #error_code = 123121
        #return error_code
    
    # Interface & Update Target #
    target_pos = get_pose('M_prBox_Load', stc=1)
  
    ready1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    complete1_pos = get_pose(target_pos, tlz=50, stc=1)
  
    # Move Function #  
    movej('M_prBox_Load_Ready',r=-1, stc=1)
    movej(ready1_pos,r=-1)
    #mio_out(OUT_LEFT_TOOL_VAC1_ON,on)
    movel(target_pos,r=-1)
    mwait(2)
    movel(complete1_pos,r=-1)
    movej('M_prBox_Load_Ready', stc=1)
  
    # Sub Motion #
  
    # Program End #
    return error_code
  
