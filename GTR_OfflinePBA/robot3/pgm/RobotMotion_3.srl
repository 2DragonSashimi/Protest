def isInPosition(position):
    cur_pos = get_pose(crd=0)
    target_pos = get_pose(position, crd=0)
    x = target_pos.x - cur_pos.x
    y = target_pos.y - cur_pos.y

    if abs(x) <= 50 and abs(y) <= 50:
        # output(f'isIn{target_pos} True')
        return True
    else:
        output(f'isIn{target_pos} False')
        return False